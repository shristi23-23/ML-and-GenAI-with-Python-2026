#Create a function to reverse a number
def reverse():
    num = int(input("Enter number to be reversed: "))
    reversed_num = 0
    while num > 0:
        remainder = num % 10
        reversed_num = (reversed_num * 10) + remainder
        num = num // 10
    print(reversed_num, "is the reversed number")

reverse()
    
